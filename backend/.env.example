# =============================================
# CloudStudy Backend Environment Variables
# =============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit the .env file to Git.
# =============================================

# --- Flask ---
FLASK_ENV         = development
FLASK_PORT        = 5000
FLASK_SECRET_KEY  = change-me-to-a-random-string

# --- AWS General ---
AWS_REGION            = us-east-1
# For local dev, paste credentials from Learner Lab → AWS Details → AWS CLI
AWS_ACCESS_KEY_ID     = 
AWS_SECRET_ACCESS_KEY = 
AWS_SESSION_TOKEN     = 

# --- S3 ---
S3_BUCKET_NAME  = cloudstudy-uploads
S3_REGION       = us-east-1

# --- RDS (MySQL) ---
RDS_HOST      = 
RDS_PORT      = 3306
RDS_DATABASE  = cloudstudy
RDS_USERNAME  = admin
RDS_PASSWORD  = 

# --- Google Gemini ---
GEMINI_API_KEY = 

# --- Cognito ---
COGNITO_USER_POOL_ID  = 
COGNITO_CLIENT_ID     = 
COGNITO_REGION        = us-east-1
