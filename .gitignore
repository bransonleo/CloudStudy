# =============================================
# CloudStudy .gitignore
# =============================================

# ----- Environment Variables -----
# CRITICAL: Never commit secrets, API keys, or credentials
.env
.env.local
.env.development
.env.production
.env.staging

# ----- Python -----
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
venv/
.venv/
ENV/
env/

# Python tools
.mypy_cache/
.pytest_cache/
.coverage
htmlcov/
*.cover

# ----- Node / Frontend -----
node_modules/
dist/
build/
.vite/
*.tsbuildinfo
.eslintcache

# ----- IDE & Editors -----
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
*.code-workspace

# ----- OS Files -----
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini
._*
*~

# ----- AWS -----
# Local AWS credential overrides (the real creds come from .env)
.aws/

# ----- Logs -----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ----- Misc -----
*.bak
*.tmp
*.temp
*.pid
