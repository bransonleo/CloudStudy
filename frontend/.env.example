# Cognito OAuth2 Configuration
# Get these values from your teammate who set up Cognito on AWS

# Full Cognito Hosted UI domain URL
VITE_COGNITO_DOMAIN=https://your-domain.auth.us-east-1.amazoncognito.com

# Cognito App Client ID
VITE_COGNITO_CLIENT_ID=your-client-id-here

# Cognito User Pool ID (required for TOTP MFA setup)
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX

# Callback URL (must match what's registered in Cognito App Client)
VITE_COGNITO_REDIRECT_URI=http://localhost:5173/callback
